# Шаблон production-env. Скопировать в .env.production и заполнить.
# ⚠️ .env.production в git НЕ коммитится (см. .gitignore .env*).

# MySQL — на том же sky.sinel.me, что и приложение, поэтому 127.0.0.1
DATABASE_URL="mysql://pogoda:ВПИШИ_ПАРОЛЬ@127.0.0.1:3306/pogoda"
SHADOW_DATABASE_URL="mysql://pogoda:ВПИШИ_ПАРОЛЬ@127.0.0.1:3306/pogoda_shadow"

# BigDataCloud — обратное геокодирование (координаты → город) для /api/reverse-geocode.
# Опционально: без ключа используется бесплатный endpoint /reverse-geocode-client.
# С ключом — платный /reverse-geocode (точнее). Регистрация: https://www.bigdatacloud.com/
# BIGDATACLOUD_API_KEY=
